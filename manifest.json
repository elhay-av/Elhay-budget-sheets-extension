{
  "manifest_version": 3,
  "name": "Finanda Export Bridge",
  "version": "1.0",
  "description": "Bridges Google Apps Script sidebar with Finanda API to export data.",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "host_permissions": [
    "https://cloud.finanda.co.il/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://docs.google.com/*",
        "https://*.googleusercontent.com/*",
        "file:///*"
      ],
      "all_frames": true,
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ]
}